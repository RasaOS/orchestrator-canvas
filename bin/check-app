#!/usr/bin/env python3
"""check-app — audit a canvas app directory against content/APP_MODEL.md.

Usage: check-app <app-dir>

Checks (FAIL = red, blocks publish; WARN = advisory):
  - app.json shape (rasa.app.v1, kebab id, semver, required fields)
  - screens[] registry exhaustive both ways (no orphan files, no missing files)
  - active_screen registered; at most one default screen
  - each screen file: valid rasa.layout.v1, screen.name == screen id,
    unique region ids, components in the kernel allowlist (warn outside the
    shell-rendered subset)
  - event coverage: every emittable action registered in app.json#events;
    stale registry rows warned. Emission grammar mirrors the shell renderer
    (verified 2026-07-09): button-row emits intent (else 'on_click' — warned);
    card-strip/card-list with on_card_click emit 'on_card_click'; form emits
    'on_submit'; a non-form region with props.on_click emits 'on_click';
    artifact rasa.emit calls are scanned from code-block{render:true}
  - nav contract on multi-screen apps: a button-row 'nav' region reaching
    every sibling; nav:* targets are registered screens
  - size budgets: layout warn >28KB fail >32KB; artifact warn >10KB fail >16KB
  - context.json (the AUDIT index, rasa.canvas.context.v1): warn when absent,
    structurally validated when present (_schema/_audited_at/_tenant_flavor/
    _tenant_root; domain/module rows carry name+path; collections id+dir+shape)
  - bindings[] (the binding registry): ids unique; region exists on its
    screen; source is exactly one form; module sources resolve against
    context.json (fail on unknown module/collection; warn when the index is
    absent); read-write requires a writable collection AND at least one
    events[].writes[] writer; writes[] targets resolve, ops valid
  - state/*.json parse; data/*.json carry _source/_derived_at stamps

Exit 0 = GREEN (warnings allowed), 1 = RED, 2 = usage error.
"""
import json
import re
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from _contract import KERNEL_ALLOWLIST, SHELL_RENDERED

SEMVER = re.compile(r"^\d+\.\d+\.\d+$")
KEBAB = re.compile(r"^[a-z0-9]+(-[a-z0-9]+)*$")
DATE = re.compile(r"^\d{4}-\d{2}-\d{2}$")
EMIT = re.compile(r"rasa\s*\.\s*emit\s*\(\s*['\"]([^'\"]+)['\"]")

LAYOUT_WARN, LAYOUT_FAIL = 28 * 1024, 32 * 1024
ARTIFACT_WARN, ARTIFACT_FAIL = 10 * 1024, 16 * 1024

findings = []


def fail(msg):
    findings.append(("FAIL", msg))


def warn(msg):
    findings.append(("WARN", msg))


def load_json(path):
    try:
        return json.loads(path.read_text())
    except Exception as e:
        fail(f"{path.name}: not valid JSON ({e})")
        return None


def screen_actions(doc, where):
    """Every action this layout can emit — mirrors the shell's emission grammar.

    The shell (frontend-rasaos components.tsx, verified 2026-07-09) emits:
    button-row → intent || 'on_click' (button_id in payload); card-strip/card-list
    with props.on_card_click → 'on_card_click'; form → 'on_submit'; any non-form
    region with props.on_click → 'on_click'; artifacts → rasa.emit(action) calls.
    """
    actions = set()
    for region in doc.get("regions") or []:
        comp = region.get("component")
        props = region.get("props") or {}
        rid = region.get("id", "?")
        if comp == "button-row":
            for b in props.get("buttons") or []:
                if not isinstance(b, dict):
                    continue
                if b.get("intent"):
                    actions.add(str(b["intent"]))
                elif b.get("id"):
                    actions.add("on_click")
                    warn(f"{where}#{rid}: button '{b['id']}' has no intent — the shell "
                         f"emits ambiguous 'on_click' (set intent to the action name)")
        if comp in ("card-strip", "card-list") and props.get("on_card_click"):
            actions.add("on_card_click")
        if comp == "form":
            actions.add("on_submit")
        if comp != "form" and props.get("on_click"):
            actions.add("on_click")
        if comp == "code-block" and props.get("render"):
            actions |= set(EMIT.findall(props.get("code", "")))
    return actions


def check_manifest(m):
    if m.get("app") != "rasa.app.v1":
        fail(f"app.json: #app is '{m.get('app')}' — must be 'rasa.app.v1'")
    for key in ("id", "name", "version", "created", "screens", "active_screen", "events"):
        if key not in m:
            fail(f"app.json: required field '{key}' missing")
    if "id" in m and not KEBAB.match(str(m["id"])):
        fail(f"app.json: id '{m['id']}' is not kebab-case")
    if "version" in m and not SEMVER.match(str(m["version"])):
        fail(f"app.json: version '{m['version']}' is not semver")
    if "created" in m and not DATE.match(str(m["created"])):
        fail(f"app.json: created '{m['created']}' is not YYYY-MM-DD")


def check_screen_registry(m):
    screens = m.get("screens") or []
    ids = []
    for s in screens:
        if not isinstance(s, dict) or not s.get("id"):
            fail("app.json#screens: row without an id")
            continue
        sid = str(s["id"])
        if sid in ids:
            fail(f"app.json#screens: duplicate screen id '{sid}'")
        ids.append(sid)
        if not KEBAB.match(sid):
            fail(f"app.json#screens: id '{sid}' is not kebab-case")
        if not s.get("title"):
            fail(f"app.json#screens['{sid}']: title missing")
    if sum(1 for s in screens if isinstance(s, dict) and s.get("default")) > 1:
        fail("app.json#screens: more than one default screen")
    active = m.get("active_screen")
    if active and active not in ids:
        fail(f"app.json: active_screen '{active}' is not a registered screen")
    return ids


def check_events_registry(m):
    reg = {}
    for row in m.get("events") or []:
        if not isinstance(row, dict) or not row.get("action"):
            fail("app.json#events: row without an action")
            continue
        a = str(row["action"])
        if a in reg:
            fail(f"app.json#events: duplicate action '{a}'")
        reg[a] = row
        if not row.get("handling"):
            fail(f"app.json#events['{a}']: no handling declared")
        if not row.get("emits"):
            fail(f"app.json#events['{a}']: no emits[] regions declared")
    return reg


def check_screen_file(path, sid, ids):
    """Returns (actions, region_ids) or (set(), set()) on parse failure."""
    doc = load_json(path)
    if doc is None:
        return set(), set()
    if doc.get("layout") != "1.0.0":
        warn(f"{path.name}: layout version '{doc.get('layout')}' (expected '1.0.0')")
    scr = doc.get("screen") or {}
    if scr.get("name") != sid:
        fail(f"{path.name}: screen.name '{scr.get('name')}' must equal the screen id '{sid}'")
    if not scr.get("title"):
        fail(f"{path.name}: screen.title missing")
    regions = doc.get("regions")
    if not isinstance(regions, list) or not regions:
        fail(f"{path.name}: regions[] missing or empty")
        return set(), set()

    rids = []
    for r in regions:
        rid = r.get("id")
        if not rid:
            fail(f"{path.name}: region without an id")
            continue
        if rid in rids:
            fail(f"{path.name}: duplicate region id '{rid}'")
        rids.append(rid)
        comp = r.get("component")
        props = r.get("props") or {}
        if comp not in KERNEL_ALLOWLIST:
            fail(f"{path.name}#{rid}: component '{comp}' is not in the kernel allowlist")
        elif comp not in SHELL_RENDERED:
            warn(f"{path.name}#{rid}: '{comp}' is allowlisted but the shell error-tiles it — prefer the rendered subset")
        if comp == "code-block" and props.get("render"):
            n = len(str(props.get("code", "")).encode())
            if n > ARTIFACT_FAIL:
                fail(f"{path.name}#{rid}: artifact is {n}B — exceeds the {ARTIFACT_FAIL}B hard cap")
            elif n > ARTIFACT_WARN:
                warn(f"{path.name}#{rid}: artifact is {n}B — over the ~10KB budget")

    n = path.stat().st_size
    if n > LAYOUT_FAIL:
        fail(f"{path.name}: layout is {n}B — exceeds the {LAYOUT_FAIL}B hard cap")
    elif n > LAYOUT_WARN:
        warn(f"{path.name}: layout is {n}B — nearing the ~32KB cap")

    # nav contract (multi-screen apps only)
    if len(ids) > 1:
        nav = next((r for r in regions if r.get("id") == "nav"), None)
        if nav is None:
            fail(f"{path.name}: multi-screen app but no 'nav' region (nav contract, APP_MODEL.md)")
        elif nav.get("component") != "button-row":
            fail(f"{path.name}#nav: nav region must be a button-row")
        else:
            buttons = (nav.get("props") or {}).get("buttons") or []
            targets = {str(b.get("intent", ""))[4:] for b in buttons
                       if isinstance(b, dict) and str(b.get("intent", "")).startswith("nav:")}
            missing = set(ids) - {sid} - targets
            if missing:
                fail(f"{path.name}#nav: missing nav button(s) for sibling screen(s): {', '.join(sorted(missing))}")
            unknown = targets - set(ids)
            if unknown:
                fail(f"{path.name}#nav: nav target(s) are not registered screens: {', '.join(sorted(unknown))}")

    return screen_actions(doc, path.name), set(rids)


CONTEXT_FLAVORS = ("holding-folder", "co-located", "canon-author")


def check_context(app):
    """context.json — the AUDIT index (rasa.canvas.context.v1). Warn when
    absent (audit not yet run); structurally validate when present.
    Returns the parsed doc (or None) so check_bindings can resolve against it."""
    p = app / "context.json"
    if not p.is_file():
        warn("context.json: missing — AUDIT not yet run (PROCESSES.md §AUDIT)")
        return None
    doc = load_json(p)
    if doc is None:
        return None
    if doc.get("_schema") != "rasa.canvas.context.v1":
        fail(f"context.json: _schema '{doc.get('_schema')}' — must be 'rasa.canvas.context.v1'")
    if not doc.get("_audited_at"):
        fail("context.json: _audited_at missing")
    if doc.get("_tenant_flavor") not in CONTEXT_FLAVORS:
        fail(f"context.json: _tenant_flavor '{doc.get('_tenant_flavor')}' — must be one of {'|'.join(CONTEXT_FLAVORS)}")
    if not doc.get("_tenant_root"):
        fail("context.json: _tenant_root missing")
    for key in ("domains", "modules"):
        for row in doc.get(key) or []:
            if not isinstance(row, dict) or not row.get("name") or not row.get("path"):
                fail(f"context.json#{key}: row without name+path")
    for m in doc.get("modules") or []:
        if not isinstance(m, dict):
            continue
        for c in m.get("collections") or []:
            if not isinstance(c, dict) or not c.get("id") or not c.get("dir") or not c.get("shape"):
                fail(f"context.json#modules['{m.get('name')}']: collection row without id+dir+shape")
    return doc


WRITE_OPS = ("create-record", "update-record", "move-record", "delete-record")


def check_bindings(m, ids, screen_regions, context_doc):
    """bindings[] — the binding registry (APP_MODEL.md §bindings).
    Returns {binding id: row} for the writes[] cross-check."""
    bids = {}
    for b in m.get("bindings") or []:
        if not isinstance(b, dict) or not b.get("id"):
            fail("app.json#bindings: row without an id")
            continue
        bid = str(b["id"])
        if bid in bids:
            fail(f"app.json#bindings: duplicate binding id '{bid}'")
        bids[bid] = b
        scr, reg = b.get("screen"), b.get("region")
        if scr not in ids:
            fail(f"app.json#bindings['{bid}']: screen '{scr}' is not a registered screen")
        elif reg not in screen_regions.get(scr, set()):
            fail(f"app.json#bindings['{bid}']: region '{reg}' not found on screen '{scr}'")
        src = b.get("source") or {}
        forms = [k for k in ("module", "tenant", "context") if src.get(k)]
        if len(forms) != 1:
            fail(f"app.json#bindings['{bid}']: source must be exactly one of "
                 f"module+collection | tenant | context (got: {forms or 'none'})")
        if src.get("module"):
            if not src.get("collection"):
                fail(f"app.json#bindings['{bid}']: module source without a collection")
            if context_doc is None:
                warn(f"app.json#bindings['{bid}']: cannot resolve module "
                     f"'{src['module']}' — context.json absent (run AUDIT)")
            else:
                mods = {str(mm.get("name")): mm
                        for mm in (context_doc.get("modules") or []) if isinstance(mm, dict)}
                mod = mods.get(str(src["module"]))
                if mod is None:
                    fail(f"app.json#bindings['{bid}']: source.module '{src['module']}' "
                         f"is not in context.json#modules")
                else:
                    colls = {str(c.get("id")): c
                             for c in (mod.get("collections") or []) if isinstance(c, dict)}
                    cid = str(src.get("collection", "")).split("/")[0]
                    coll = colls.get(cid)
                    if coll is None:
                        fail(f"app.json#bindings['{bid}']: collection '{src.get('collection')}' "
                             f"is not declared by '{src['module']}' in context.json")
                    elif b.get("direction") == "read-write" and not coll.get("writable"):
                        fail(f"app.json#bindings['{bid}']: read-write on a collection "
                             f"context.json does not mark writable")
        sel = src.get("select")
        if sel not in (None, "*"):
            warn(f"app.json#bindings['{bid}']: select '{sel}' — v1 supports only '*'")
    return bids


def check_writes(m, bids):
    """events[].writes[] — every target resolves; read-write bindings have a writer."""
    writers = set()
    for row in m.get("events") or []:
        if not isinstance(row, dict):
            continue
        a = row.get("action")
        for w in row.get("writes") or []:
            if not isinstance(w, dict):
                fail(f"app.json#events['{a}']: writes[] entry is not an object")
                continue
            if w.get("binding"):
                if str(w["binding"]) not in bids:
                    fail(f"app.json#events['{a}']: writes[] names unknown binding '{w['binding']}'")
                else:
                    writers.add(str(w["binding"]))
                if w.get("op") not in WRITE_OPS:
                    fail(f"app.json#events['{a}']: writes[] op '{w.get('op')}' — "
                         f"must be one of {'|'.join(WRITE_OPS)}")
            elif w.get("state"):
                pass  # app-local state write — always legal
            else:
                fail(f"app.json#events['{a}']: writes[] entry needs binding+op or state")
    for bid, b in bids.items():
        if b.get("direction") == "read-write" and bid not in writers:
            fail(f"app.json#bindings['{bid}']: read-write but no event writes it "
                 f"(declare a writes[] entry or make it read)")


def check_hygiene(app):
    state = app / "state"
    if state.is_dir():
        for p in sorted(state.glob("*.json")):
            load_json(p)
    data = app / "data"
    if data.is_dir():
        for p in sorted(data.glob("*.json")):
            doc = load_json(p)
            if isinstance(doc, dict) and ("_source" not in doc or "_derived_at" not in doc):
                warn(f"data/{p.name}: derived data without _source/_derived_at stamps")
    if not (app / "CHANGELOG.md").is_file():
        warn("CHANGELOG.md: missing (one line per shipped change)")


def report():
    for kind, msg in findings:
        print(f"{kind}  {msg}")
    n_fail = sum(1 for k, _ in findings if k == "FAIL")
    n_warn = sum(1 for k, _ in findings if k == "WARN")
    print(f"{'RED' if n_fail else 'GREEN'} — {n_fail} fail, {n_warn} warn")
    return 1 if n_fail else 0


def main():
    if len(sys.argv) != 2:
        print(__doc__.strip().splitlines()[2])
        return 2
    app = Path(sys.argv[1]).resolve()
    manifest_path = app / "app.json"
    if not manifest_path.is_file():
        fail("app.json: missing — not an app directory (BOOTSTRAP not run?)")
        return report()
    m = load_json(manifest_path)
    if m is None:
        return report()

    check_manifest(m)
    ids = check_screen_registry(m)
    reg = check_events_registry(m)

    screens_dir = app / "screens"
    files = {p.stem: p for p in screens_dir.glob("*.json")} if screens_dir.is_dir() else {}
    if not screens_dir.is_dir():
        fail("screens/: directory missing")
    for sid in ids:
        if sid not in files:
            fail(f"screens/{sid}.json: registered in app.json#screens but the file is missing")
    for stem in sorted(set(files) - set(ids)):
        fail(f"screens/{stem}.json: orphan screen file — not registered in app.json#screens")

    emitted = {}   # action -> {screen ids that emit it}
    all_region_ids = set()
    screen_regions = {}   # screen id -> {region ids on that screen}
    for sid in sorted(set(ids) & set(files)):
        actions, rids = check_screen_file(files[sid], sid, ids)
        all_region_ids |= rids
        screen_regions[sid] = rids
        for a in actions:
            emitted.setdefault(a, set()).add(sid)

    # event coverage
    for a, sids in sorted(emitted.items()):
        if a.startswith("nav:") and a[4:] not in ids:
            fail(f"action '{a}' (emitted by {', '.join(sorted(sids))}) targets an unregistered screen")
        if a not in reg:
            fail(f"action '{a}' is emitted by screen(s) {', '.join(sorted(sids))} but not registered in app.json#events")
    for a, row in sorted(reg.items()):
        if a not in emitted:
            warn(f"app.json#events['{a}']: registered but no published screen emits it (stale row?)")
            continue
        for region in row.get("emits") or []:
            if region not in all_region_ids:
                warn(f"app.json#events['{a}']: emits region '{region}' not found on any screen")

    ctx = check_context(app)
    bids = check_bindings(m, ids, screen_regions, ctx)
    check_writes(m, bids)
    check_hygiene(app)
    return report()


if __name__ == "__main__":
    sys.exit(main())
